# Environment Variables for CIFAKE Project

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=your-secret-key-change-in-production

# Upload Configuration
MAX_UPLOAD_SIZE=10485760
UPLOAD_FOLDER=static/uploads
ALLOWED_EXTENSIONS=png,jpg,jpeg

# Database Configuration
DATABASE_PATH=predictions.db

# Model Configuration
MODEL_PATH=models/best_model.hdf5
MODEL_INPUT_SIZE=32

# Logging
LOG_LEVEL=INFO

# API Configuration
API_HOST=0.0.0.0
API_PORT=5000

# Performance Tuning
BATCH_SIZE=32
NUM_WORKERS=4

# Data Paths
DATASET_DIR=dataset
MODELS_DIR=models
OUTPUTS_DIR=outputs
